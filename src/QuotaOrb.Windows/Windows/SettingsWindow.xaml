<Window x:Class="QuotaOrb.Windows.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Balance Capsule 设置"
        Width="360"
        Height="300"
        MinWidth="340"
        MinHeight="280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F7F4EF"
        FontFamily="Microsoft YaHei UI"
        ShowInTaskbar="True">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Balance Capsule"
                       FontFamily="Segoe UI Variable Display, Microsoft YaHei UI"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#304A59" />
            <TextBlock Margin="0,4,0,0"
                       Text="轻量、安静地显示 Codex 与 Claude 剩余用量"
                       FontSize="11"
                       Foreground="#849198" />
        </StackPanel>

        <Border Grid.Row="2"
                Padding="18,12"
                Background="#FFFCF8"
                BorderBrush="#E7E0D7"
                BorderThickness="1"
                CornerRadius="16">
            <StackPanel VerticalAlignment="Center">
                <CheckBox x:Name="StartWithWindowsCheckBox"
                          Content="随 Windows 启动"
                          Margin="0,8"
                          FontSize="13"
                          Foreground="#3E5664" />
                <CheckBox x:Name="HideInFullscreenCheckBox"
                          Content="全屏时自动隐藏"
                          Margin="0,8"
                          FontSize="13"
                          Foreground="#3E5664" />
                <CheckBox x:Name="AnimationsEnabledCheckBox"
                          Content="启用呼吸动画"
                          Margin="0,8"
                          FontSize="13"
                          Foreground="#3E5664" />
            </StackPanel>
        </Border>

        <Button Grid.Row="3"
                Width="92"
                Height="34"
                Margin="0,16,0,0"
                HorizontalAlignment="Right"
                Content="完成"
                IsDefault="True"
                Click="OnDoneClicked"
                Background="#A8CDEC"
                BorderBrush="#8CB9DE"
                Foreground="#24485E"
                FontWeight="SemiBold" />
    </Grid>
</Window>
