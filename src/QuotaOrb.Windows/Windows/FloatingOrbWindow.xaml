<Window x:Class="QuotaOrb.Windows.Windows.FloatingOrbWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="Balance Capsule 悬浮球"
        Width="78"
        Height="78"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Focusable="False"
        SnapsToDevicePixels="True"
        automation:AutomationProperties.Name="Balance Capsule 额度状态">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibility" />

        <Storyboard x:Key="AmbientMotionStoryboard">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="OrbTranslateY"
                                           Storyboard.TargetProperty="Y"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="2" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.1" Value="-7">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:4.2" Value="2">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="OrbRotate"
                                           Storyboard.TargetProperty="Angle"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="-0.6" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.1" Value="0.6" />
                <EasingDoubleKeyFrame KeyTime="0:0:4.2" Value="-0.6" />
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GroundShadowScale"
                                           Storyboard.TargetProperty="ScaleX"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.78" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.1" Value="1.12" />
                <EasingDoubleKeyFrame KeyTime="0:0:4.2" Value="0.78" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GroundShadowScale"
                                           Storyboard.TargetProperty="ScaleY"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.78" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.1" Value="1.12" />
                <EasingDoubleKeyFrame KeyTime="0:0:4.2" Value="0.78" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GroundShadow"
                                           Storyboard.TargetProperty="Opacity"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.50" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.1" Value="0.20" />
                <EasingDoubleKeyFrame KeyTime="0:0:4.2" Value="0.50" />
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AuraScale"
                                           Storyboard.TargetProperty="ScaleX"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.96" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.1" Value="1.06" />
                <EasingDoubleKeyFrame KeyTime="0:0:4.2" Value="0.96" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AuraScale"
                                           Storyboard.TargetProperty="ScaleY"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.96" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.1" Value="1.06" />
                <EasingDoubleKeyFrame KeyTime="0:0:4.2" Value="0.96" />
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FrontLiquidTranslate"
                                           Storyboard.TargetProperty="X"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="-7" />
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="7" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="-7" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FrontLiquidRotate"
                                           Storyboard.TargetProperty="Angle"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="-2" />
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="2" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="-2" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BackLiquidTranslate"
                                           Storyboard.TargetProperty="X"
                                           BeginTime="0:0:1.2"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="7" />
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="-7" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="7" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BackLiquidRotate"
                                           Storyboard.TargetProperty="Angle"
                                           BeginTime="0:0:1.2"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="2" />
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="-2" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="2" />
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimation Storyboard.TargetName="Bubble1Translate"
                             Storyboard.TargetProperty="Y"
                             From="10" To="-18" Duration="0:0:3"
                             RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="Bubble1"
                             Storyboard.TargetProperty="Opacity"
                             From="0.68" To="0" Duration="0:0:3"
                             RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="Bubble2Translate"
                             Storyboard.TargetProperty="Y"
                             From="10" To="-18" BeginTime="0:0:1"
                             Duration="0:0:3" RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="Bubble2"
                             Storyboard.TargetProperty="Opacity"
                             From="0.62" To="0" BeginTime="0:0:1"
                             Duration="0:0:3" RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="Bubble3Translate"
                             Storyboard.TargetProperty="Y"
                             From="10" To="-18" BeginTime="0:0:2"
                             Duration="0:0:3" RepeatBehavior="Forever" />
            <DoubleAnimation Storyboard.TargetName="Bubble3"
                             Storyboard.TargetProperty="Opacity"
                             From="0.64" To="0" BeginTime="0:0:2"
                             Duration="0:0:3" RepeatBehavior="Forever" />

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SweepTranslate"
                                           Storyboard.TargetProperty="X"
                                           RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="-80" />
                <DiscreteDoubleKeyFrame KeyTime="0:0:2.3" Value="-80" />
                <EasingDoubleKeyFrame KeyTime="0:0:3.3" Value="80">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseInOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <DiscreteDoubleKeyFrame KeyTime="0:0:4.2" Value="80" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="HoverInStoryboard">
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="1.04" Duration="0:0:0.16" />
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="1.04" Duration="0:0:0.16" />
        </Storyboard>
        <Storyboard x:Key="HoverOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="1" Duration="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetName="OrbScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="1" Duration="0:0:0.12" />
        </Storyboard>
        <Storyboard x:Key="StateWashStoryboard">
            <DoubleAnimation Storyboard.TargetName="StateWash"
                             Storyboard.TargetProperty="Opacity"
                             From="0.34" To="0.10" Duration="0:0:0.24" />
        </Storyboard>
        <Storyboard x:Key="ErrorPulseStoryboard">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AuraScale"
                                           Storyboard.TargetProperty="ScaleX"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.98" />
                <EasingDoubleKeyFrame KeyTime="0:0:1.4" Value="1.08" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.8" Value="0.98" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AuraScale"
                                           Storyboard.TargetProperty="ScaleY"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.98" />
                <EasingDoubleKeyFrame KeyTime="0:0:1.4" Value="1.08" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.8" Value="0.98" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AuraRing"
                                           Storyboard.TargetProperty="Opacity"
                                           RepeatBehavior="Forever">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.18" />
                <EasingDoubleKeyFrame KeyTime="0:0:1.4" Value="0.34" />
                <EasingDoubleKeyFrame KeyTime="0:0:2.8" Value="0.18" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
    <Grid x:Name="OrbRoot" Width="112" Height="112" Background="Transparent">
        <Grid x:Name="ShadowLayer" IsHitTestVisible="False">
            <Ellipse x:Name="GroundShadow"
                     Width="62"
                     Height="14"
                     Margin="0,0,0,4"
                     VerticalAlignment="Bottom"
                     Fill="#5960798C"
                     Opacity="0.50"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.Effect>
                    <BlurEffect Radius="7" />
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="GroundShadowScale" ScaleX="0.78" ScaleY="0.78" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse x:Name="AuraRing"
                     Width="94"
                     Height="94"
                     Fill="{Binding LiquidBrush}"
                     Opacity="0.16"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.Effect>
                    <BlurEffect Radius="12" />
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="AuraScale" ScaleX="0.96" ScaleY="0.96" />
                </Ellipse.RenderTransform>
            </Ellipse>
        </Grid>

        <Grid x:Name="OrbVisual"
              Width="84"
              Height="84"
              IsHitTestVisible="False"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="OrbScale" ScaleX="1" ScaleY="1" />
                    <RotateTransform x:Name="OrbRotate" Angle="-0.6" />
                    <TranslateTransform x:Name="OrbTranslateY" Y="2" />
                </TransformGroup>
            </Grid.RenderTransform>

            <Ellipse x:Name="OuterGlassRim" Width="84" Height="84">
                <Ellipse.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#FFFFFFFF" />
                        <GradientStop Offset="0.42" Color="#FFD7F0FB" />
                        <GradientStop Offset="0.70" Color="#FF83B3D1" />
                        <GradientStop Offset="1" Color="#FFF8FCFF" />
                    </LinearGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="7"
                                      Opacity="0.30"
                                      Color="#456F8B" />
                </Ellipse.Effect>
            </Ellipse>

            <Grid Width="68" Height="68">
                <Grid.Clip>
                    <EllipseGeometry Center="34,34" RadiusX="34" RadiusY="34" />
                </Grid.Clip>

                <Ellipse>
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.36,0.27"
                                             GradientOrigin="0.28,0.20"
                                             RadiusX="0.78"
                                             RadiusY="0.78">
                            <GradientStop Offset="0" Color="#FFFFFFFF" />
                            <GradientStop Offset="0.48" Color="#FFF3FAFD" />
                            <GradientStop Offset="1" Color="#FFD4E8F3" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Grid x:Name="BackLiquid"
                      Height="{Binding LiquidHeight}"
                      Margin="-8,0"
                      VerticalAlignment="Bottom"
                      RenderTransformOrigin="0.5,0.5"
                      Opacity="0.58">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="BackLiquidRotate" Angle="2" />
                            <TranslateTransform x:Name="BackLiquidTranslate" X="7" />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Rectangle Margin="0,3,0,0" Fill="{Binding LiquidBrush}" />
                    <Ellipse Height="8" Margin="-5,-3,-5,0" VerticalAlignment="Top" Fill="{Binding LiquidBrush}" />
                </Grid>

                <Grid x:Name="FrontLiquid"
                      Height="{Binding LiquidHeight}"
                      Margin="-8,0"
                      VerticalAlignment="Bottom"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="FrontLiquidRotate" Angle="-2" />
                            <TranslateTransform x:Name="FrontLiquidTranslate" X="-7" />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Rectangle Margin="0,3,0,0" Fill="{Binding LiquidBrush}" />
                    <Ellipse Height="8" Margin="-5,-3,-5,0" VerticalAlignment="Top" Fill="#88FFFFFF" />
                </Grid>

                <Ellipse x:Name="StateWash" Fill="{Binding LiquidBrush}" Opacity="0.10" />

                <Ellipse x:Name="TickRing"
                         Margin="8"
                         Stroke="#66366F92"
                         StrokeThickness="1"
                         StrokeDashArray="1,5" />

                <Canvas Visibility="{Binding IsDataAvailable, Converter={StaticResource BooleanToVisibility}}">
                    <Ellipse x:Name="Bubble1"
                             Canvas.Left="17"
                             Canvas.Top="45"
                             Width="5"
                             Height="5"
                             Stroke="#CFFFFFFF"
                             StrokeThickness="1"
                             Opacity="0.68">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="Bubble1Translate" Y="10" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="Bubble2"
                             Canvas.Left="46"
                             Canvas.Top="50"
                             Width="3"
                             Height="3"
                             Stroke="#BFFFFFFF"
                             StrokeThickness="1"
                             Opacity="0.62">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="Bubble2Translate" Y="10" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="Bubble3"
                             Canvas.Left="38"
                             Canvas.Top="54"
                             Width="4"
                             Height="4"
                             Stroke="#CFFFFFFF"
                             StrokeThickness="1"
                             Opacity="0.64">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="Bubble3Translate" Y="10" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Canvas>

                <Border Width="37"
                        Height="11"
                        Margin="0,6,0,0"
                        VerticalAlignment="Top"
                        Background="#99FFFFFF"
                        BorderBrush="#C8FFFFFF"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="3.5" Height="3.5" Margin="0,0,3,0" Fill="#62C5A6" />
                        <TextBlock Text="QUOTA"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="5.5"
                                   FontWeight="Bold"
                                   Foreground="#456E86" />
                    </StackPanel>
                </Border>

                <StackPanel VerticalAlignment="Center" Margin="0,2,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding DisplayText}"
                                   FontFamily="Segoe UI Variable Display, Microsoft YaHei UI"
                                   FontSize="{Binding CompactDisplayFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="#234D69" />
                        <TextBlock x:Name="PercentSuffix"
                                   Text="%"
                                   Margin="2,8,0,0"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="#557A91"
                                   Visibility="{Binding ShowsPercent, Converter={StaticResource BooleanToVisibility}}" />
                    </StackPanel>
                    <TextBlock x:Name="CompactCaption"
                               Margin="0,-3,0,0"
                               Text="{Binding CaptionText}"
                               HorizontalAlignment="Center"
                               FontFamily="Segoe UI Variable Text, Microsoft YaHei UI"
                               FontSize="5.5"
                               FontWeight="Bold"
                               Foreground="#6D8595" />
                </StackPanel>

                <Ellipse Width="31"
                         Height="18"
                         Margin="7,8,0,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Fill="#8AFFFFFF"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="-28" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Rectangle x:Name="SweepHighlight"
                           Width="12"
                           Height="98"
                           HorizontalAlignment="Left"
                           Opacity="0.72"
                           RenderTransformOrigin="0.5,0.5">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#00FFFFFF" />
                            <GradientStop Offset="0.5" Color="#C8FFFFFF" />
                            <GradientStop Offset="1" Color="#00FFFFFF" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.RenderTransform>
                        <TransformGroup>
                            <RotateTransform Angle="-24" />
                            <TranslateTransform x:Name="SweepTranslate" X="-80" />
                        </TransformGroup>
                    </Rectangle.RenderTransform>
                </Rectangle>
            </Grid>

            <Ellipse x:Name="InnerGlassRim"
                     Width="72"
                     Height="72"
                     Fill="Transparent"
                     Stroke="#BFFFFFFF"
                     StrokeThickness="2" />
            <Ellipse Width="78"
                     Height="78"
                     Fill="Transparent"
                     Stroke="#52638FAB"
                     StrokeThickness="1" />
        </Grid>

        <Grid x:Name="OrbHitTarget"
              Width="84"
              Height="84"
              Background="#01FFFFFF"
              MouseLeftButtonDown="OnMouseLeftButtonDown"
              MouseEnter="OnHoverEntered"
              MouseLeave="OnHoverLeft">
            <Grid.ContextMenu>
                <ContextMenu Background="#FFFCF8" BorderBrush="#E5DED5">
                    <MenuItem Header="立即刷新" Click="OnRefreshClicked" />
                    <MenuItem Header="数据来源">
                        <MenuItem x:Name="CodexAgentMenuItem"
                                  Header="Codex"
                                  IsCheckable="True"
                                  Click="OnCodexAgentClicked" />
                        <MenuItem x:Name="ClaudeAgentMenuItem"
                                  Header="Claude Desktop"
                                  IsCheckable="True"
                                  Visibility="Collapsed"
                                  Click="OnClaudeAgentClicked" />
                        <MenuItem x:Name="ClaudeCodeAgentMenuItem"
                                  Header="Claude Code"
                                  IsCheckable="True"
                                  Click="OnClaudeCodeAgentClicked" />
                    </MenuItem>
                    <MenuItem x:Name="QuotaWindowMenuItem"
                              Header="悬浮球显示"
                              Visibility="Collapsed">
                        <MenuItem x:Name="FiveHourQuotaMenuItem"
                                  Header="5h 限额"
                                  IsCheckable="True"
                                  Click="OnFiveHourQuotaClicked" />
                        <MenuItem x:Name="WeeklyQuotaMenuItem"
                                  Header="一周限额"
                                  IsCheckable="True"
                                  Click="OnWeeklyQuotaClicked" />
                    </MenuItem>
                    <MenuItem Header="设置">
                        <MenuItem x:Name="StartupMenuItem"
                                  Header="开机启动"
                                  IsCheckable="True"
                                  Click="OnStartupClicked" />
                        <MenuItem Header="打开设置" Click="OnSettingsClicked" />
                    </MenuItem>
                    <MenuItem Header="退出" Click="OnExitClicked" />
                </ContextMenu>
            </Grid.ContextMenu>
        </Grid>
    </Grid>
    </Viewbox>
</Window>
